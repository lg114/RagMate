# ================= LLM CONFIGURATION =================
LLM_MODEL=gpt-4o
LLM_API_KEY=your-api-key-here
LLM_API_BASE_URL=

# ================= EMBEDDING CONFIGURATION =================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_PROVIDER=huggingface
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=
HF_TOKEN=

# ================= LANGSMITH CONFIGURATION =================
LANGSMITH_API_KEY=your-langsmith-key-here
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=ragmate
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ================= DATABASE CONFIGURATION =================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ragmate
REDIS_URL=redis://localhost:6379/0

# ================= MILVUS CONFIGURATION =================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=ragmate_docs
MILVUS_TIMEOUT=10

# ================= RAG PIPELINE CONFIGURATION =================
# 文档切分
CHUNK_SIZE=1000              # 每个文本片段的字符数（越大信息越完整，但检索精度可能下降）
CHUNK_OVERLAP=200            # 相邻片段的重叠字符数（保持上下文连续性）

# 混合检索 + 重排序
HYBRID_SEARCH_ENABLED=true   # 启用稠密+稀疏混合检索（关闭则只用稠密检索）
RERANKER_MODEL=BAAI/bge-reranker-v2-m3  # 交叉编码器重排序模型
RERANK_CANDIDATES=30         # 重排序候选数量（越大越慢但质量越高）
FINAL_CONTEXT_K=15           # 最终传给 LLM 的最大片段数（动态策略的硬上限）
RERANK_SCORE_THRESHOLD=0.3   # 重排序分数阈值（sigmoid 概率，低于此值的片段被丢弃）

# ================= CORS =================
# 生产环境请限制为具体域名，如: https://your-domain.com
CORS_ORIGINS=*

# ================= DOCUMENTS =================
DOCUMENTS_DIR=./documents
